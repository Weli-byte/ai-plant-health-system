{
  "model_version": "2.0.0",
  "model_type": "XGBRegressor",
  "numeric_features": [
    "temperature",
    "humidity",
    "rainfall",
    "wind_speed"
  ],
  "category_features": [
    "season"
  ],
  "season_categories": [
    "spring",
    "summer",
    "autumn",
    "winter"
  ],
  "target": "risk_score",
  "output_range": [
    0,
    100
  ],
  "xgb_params": {
    "n_estimators": 400,
    "max_depth": 6,
    "learning_rate": 0.04,
    "subsample": 0.85,
    "colsample_bytree": 0.8,
    "min_child_weight": 3,
    "reg_alpha": 0.05,
    "reg_lambda": 1.2,
    "random_state": 42,
    "n_jobs": -1,
    "objective": "reg:squarederror"
  },
  "metrics": {
    "rmse": 2.6513,
    "r2": 0.9635,
    "n_train": 8000,
    "n_val": 2000
  },
  "serialization": "joblib"
}