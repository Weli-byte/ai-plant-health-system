# =============================================================================
# .env.example — Takım için Örnek Ortam Değişkenleri Şablonu
#
# NASIL KULLANILIR:
#   1. Bu dosyayı kopyala → cp .env.example .env
#   2. .env dosyasını kendi bilgilerinle doldur
#   3. .env dosyasını asla Git'e commit ETME (.gitignore'da zaten engellendi)
#
# Bu dosya (.env.example) Git'e eklenebilir — içinde gerçek şifre YOK.
# =============================================================================

# PostgreSQL Veritabanı Bağlantı Bilgileri
DB_HOST=localhost
DB_PORT=5432
DB_NAME=plant_health_db
DB_USER=postgres
DB_PASSWORD=BURAYA_POSTGRESQL_SIFREN

# Uygulama Ayarları
# Geliştirme ortamında DEBUG=True bırak
# Production'a alırken DEBUG=False yap
DEBUG=True

# Gizli Anahtar (JWT ve güvenlik için kullanılacak, Sprint 2)
# Uzun, rastgele bir string gir. Örnek üretmek için:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=BURAYA_UZUN_VE_RASTGELE_BIR_ANAHTAR
